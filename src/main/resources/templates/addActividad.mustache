<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Nueva actividad</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<main class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-mark">UD</span>
            <span>Usuarios & Direcciones</span>
        </a>
        <nav class="nav-actions">
            <a class="button button-secondary" href="/listUsuarios">Volver al listado</a>
        </nav>
    </header>

    <section class="page-head">
        <div class="page-title">
            {{#usuario}}
                <h1>Nueva actividad</h1>
                <p>Registra una actividad para el usuario {{nombre}}.</p>
            {{/usuario}}
        </div>
    </section>

    <section class="panel form-card">
        {{#validationError}}
            <div class="error-message">{{validationError}}</div>
        {{/validationError}}

        {{#usuario}}
            <form action="/guardarActividad" method="post">
                <input type="hidden" name="usuarioId" value="{{id}}">

                <div class="field">
                    <label for="titulo">Titulo</label>
                    <input type="text" id="titulo" name="titulo" value="{{titulo}}" required maxlength="100" placeholder="Ej. Reunion inicial">
                </div>

                <div class="field">
                    <label for="descripcion">Descripcion</label>
                    <textarea id="descripcion" name="descripcion" maxlength="500" placeholder="Detalle breve de la actividad">{{descripcion}}</textarea>
                </div>

                <div class="field">
                    <label for="fecha">Fecha</label>
                    <input type="date" id="fecha" name="fecha" value="{{fecha}}" required>
                </div>

                <div class="form-actions">
                    <button class="button-primary" type="submit">Crear actividad</button>
                    <a class="button button-secondary" href="/listUsuarios">Cancelar</a>
                </div>
            </form>
        {{/usuario}}

        {{^usuario}}
            <div class="message">No se ha encontrado el usuario.</div>
        {{/usuario}}
    </section>
</main>
</body>
</html>
