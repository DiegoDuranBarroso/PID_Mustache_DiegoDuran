<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{errorTitle}}</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<main class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-mark">UD</span>
            <span>Usuarios & Direcciones</span>
        </a>
        <nav class="nav-actions">
            <a class="button button-secondary" href="/listUsuarios">Volver al listado</a>
        </nav>
    </header>

    <section class="panel welcome-card error-page">
        <h1>{{errorTitle}}</h1>
        <p>{{errorMessage}}</p>
        <div class="hero-actions">
            <a class="button button-primary" href="/listUsuarios">Ir a usuarios</a>
            <a class="button button-secondary" href="/">Inicio</a>
        </div>
    </section>
</main>
</body>
</html>
