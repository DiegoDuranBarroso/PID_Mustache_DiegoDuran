<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Editar usuario</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<main class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-mark">UD</span>
            <span>Usuarios & Direcciones</span>
        </a>
        <nav class="nav-actions">
            <a class="button button-secondary" href="/listUsuarios">Volver al listado</a>
        </nav>
    </header>

    <section class="page-head">
        <div class="page-title">
            <h1>Editar usuario</h1>
            <p>Actualiza el nombre del usuario seleccionado.</p>
        </div>
    </section>

    <section class="panel form-card">
        {{#validationError}}
            <div class="error-message">{{validationError}}</div>
        {{/validationError}}

        {{#usuario}}
            <form action="/updateUsuario" method="post">
                <input type="hidden" name="id" value="{{id}}">

                <div class="field">
                    <label for="nombre">Nombre</label>
                    <input type="text" id="nombre" name="nombre" value="{{nombre}}" required maxlength="80">
                </div>

                <div class="form-actions">
                    <button class="button-primary" type="submit">Guardar cambios</button>
                    <a class="button button-secondary" href="/listUsuarios">Cancelar</a>
                </div>
            </form>
        {{/usuario}}

        {{^usuario}}
            <div class="message">No se ha encontrado el usuario.</div>
        {{/usuario}}
    </section>
</main>
</body>
</html>
